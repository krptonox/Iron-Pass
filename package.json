{
  "name": "ironpass",
  "version": "0.2.0",
  "description": "Password security toolkit for Node.js with PBKDF2 hashing, verification, automatic rehashing, and breached-password detection.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "prepare": "npm run lint && npm run test",
    "prepublishOnly": "npm run lint && npm run test && npm run check-format"
  },
  "keywords": [
    "password",
    "password-hashing",
    "security",
    "authentication",
    "pbkdf2",
    "crypto",
    "node",
    "nodejs"
  ],
  "author": "Aryan Yadav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krptonox/Iron-Pass.git"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "vitest": "^4.1.9"
  }
}
